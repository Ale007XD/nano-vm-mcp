# nano-vm-mcp environment variables
# Copy to .env and fill in values

# Path to SQLite database (default: nano_vm_mcp.db)
NANO_VM_MCP_DB=nano_vm_mcp.db

# SSE transport bind settings (only used with --transport=sse)
NANO_VM_MCP_HOST=0.0.0.0
NANO_VM_MCP_PORT=8080

# LLM adapter — required only for programs with llm steps
# Supports any LiteLLM model string (openrouter, groq, openai, ollama, ...)
# NANO_VM_MCP_LLM_MODEL=openrouter/llama-3.3-70b-instruct:free
# NANO_VM_MCP_LLM_MODEL=groq/llama-3.3-70b-versatile

## API key for LLM providers (if needed)
# OPENROUTER_API_KEY=sk-or-...
# GROQ_API_KEY=gsk_...

# SSE auth — bearer token (optional but strongly recommended for public deployments)
# If set, all SSE/HTTP requests must include: Authorization: Bearer <token>
# If not set, server runs without auth (suitable for local/trusted networks only)
# NANO_VM_MCP_API_KEY=your-secret-token-here
